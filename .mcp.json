{
  "mcpServers": {
    "kevin": {
      "command": "bun",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/src/server.ts"],
      "env": {
        "KEVIN_PLUGIN_ROOT": "${CLAUDE_PLUGIN_ROOT}",
        "KEVIN_PLUGIN_DATA": "${CLAUDE_PLUGIN_DATA}",
        "PLAYWRIGHT_BROWSERS_PATH": "0"
      }
    },
    "perplexity": {
      "command": "bunx",
      "args": ["@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    }
  }
}
