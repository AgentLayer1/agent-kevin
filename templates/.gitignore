# secrets
.env
.env.*
!.env.example
keys.json
certificates/
*.pem
*.key

# local overrides
.claude/settings.local.json

# runtime state (tokens, logs) — but TRACK two records that must survive a clone
# or restore: the compile cursor (the only record of what's been ingested; if
# rolled back, the next blind compile re-ingests everything and corrupts memory)
# and the template baseline (what version this home's files are reconciled to;
# if lost, upgrade-tracking resets and "are you behind?" breaks).
.kevin/*
!.kevin/knowledge.json
!.kevin/version.json

# playwright capture artifacts (screenshots, pdfs, recordings — binary, regenerable)
reports/captures/

# obsidian (per-device pane layout + cache churn on every save — vault config stays tracked)
.obsidian/workspace.json
.obsidian/cache/

# os
.DS_Store
**/.DS_Store
Thumbs.db
